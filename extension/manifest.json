{
  "manifest_version": 3,
  "name": "Medix",
  "version": "0.1.0",
  "description": "一键添加图片到 Medix 媒体库",
  "permissions": ["contextMenus", "storage", "notifications"],
  "host_permissions": ["http://localhost:*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
